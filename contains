#include <stdio.h>

int contains(int n, int tomb[], int keresett) {
    for(int i = 0; i < n ; i++) {
        if (tomb[i] == keresett) {
            return 1;
        }
    }
     return 0;
}
int main()
{
    int tomb[]={2,8,1,4,9};
    int meret = 5;
    printf("A keresett szam benne van a tombben? %d\n", contains(meret,tomb,9));
return 0;
}
