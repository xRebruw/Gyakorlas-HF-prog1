#include <stdio.h>
#include "prog1.h"
#include <string.h>

int rfind_char(string s, char c)
{
    for(int i = strlen(s) - 1; i >= 0; i--)
    {
        if(s[i] == c)
        {
            return i;
        }
    }
        return -1;
}

int main()
{
    string s ="Abba";
    char c = 'a';
    int pozicio = rfind_char(s,c);
    printf("%d\n", pozicio);
    return 0;
}
