#include <stdio.h>
#include "prog1.h"
#include <string.h>



int match_ends(int n, string words[])
{
    int db = 0;
    for(int i = 0; i<n;i++)
    {
       string s = words[i];
     int hossz = strlen(s);
        
        if (hossz >= 2 && s[0] == s[hossz - 1])
        {
            db++;
        }
    }
    return db;
}

int main()
{
    string szavak1[] = { "aba", "xyz", "aa", "x", "bbb" };
    int szavak1_meret = 5;

    printf("%d\n",match_ends(szavak1_meret,szavak1));

    for (int i = 0; i < szavak1_meret; ++i)
    {
        puts(szavak1[i]);
    }

    return 0;
}
