#include <stdio.h>
int iindex(int n, int tomb[], int keresett) {
    for (int i = 0; i < n; i++) {
        if (tomb[i] == keresett) {
            return i; 
        }
    }
    return -1; 
}
int main()
{
    int tomb[]={2,8,1,4,9};
    int meret = 5;
    printf("A keresett index: %d\n", iindex(meret,tomb,4));
return 0;
}
