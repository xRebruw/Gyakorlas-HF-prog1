#include <stdio.h>

int main() {
    
    int volt_mar[100] = {0}; 
    int beolvasott;
    int kulonbozo_db = 0;

    printf("Adj meg 0 vegjelig egesz szamokat az [1, 99] intervallumbol!\n");

    while (1) {
        printf("Szam: ");
        if (scanf("%d", &beolvasott) != 1) {
            printf("Hiba: Nem szamot adtal meg!\n");
            while(getchar() != '\n'); 
            continue;
        }

        
        if (beolvasott == 0) break;

       
        if (beolvasott < 1 || beolvasott > 99) {
            printf("Ez a szam kivul esik az elfogadhato intervallumon!\n");
        } else {

            volt_mar[beolvasott] = 1;
        }
    }

    for (int i = 1; i <= 99; i++) {
        if (volt_mar[i] == 1) {
            kulonbozo_db++;
        }
    }

    printf("\n% d db kulonbozo szam lett megadva.\n", kulonbozo_db);
    printf("Ezek (novekvo sorrendben): ");

    int elso = 1;
    for (int i = 1; i <= 99; i++) {
        if (volt_mar[i] == 1) {
            if (!elso) printf(", "); 
            printf("%d", i);
            elso = 0;
        }
    }
    printf("\n");

    return 0;
}
