#include <stdio.h>
#include "prog1.h"
#include <string.h>

int char_count(string s,char c)
{
int db = 0;
for(int i = 0; i<strlen(s);i++)
{
    if(s[i]==c)
    {
        db++;
    }
}
    return db;
}


int main()
{
    string s ="Abba";
    char c = 'a';
    int darabszam = char_count(s,c);
    printf("%d\n",darabszam );
    return 0;
}
