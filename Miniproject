#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define VERSION "1.2"

void print_help(char *program_name) {
    
    printf(
        "Hasznalat: %s [opcio|nyelv]\n\n"
        "Opciok:\n"
        "  -h, --help      //Help megjelenitese\n"
        "  -v, --version   //Verzioszam\n"
        "  --stdout        //Fajl helyett stdout-ra ir\n\n"
        "Tamogatott nyelvek:\n"
        "  c       (C)\n"
        "  cpp     (C++)\n"
        "  py      (Python)\n"
        "  bash    (Bash)\n"
        "  java    (Java)\n", 
        program_name
    );
}

void print_version() {
    printf("verzio: %s\n", VERSION);
}

void output_code(const char *filename, const char *lines[], int line_count, int stdout_mode) {
    FILE *file = NULL;
    
    if (!stdout_mode) {
        file = fopen(filename, "w");
        if (file == NULL) {
            perror("Hiba a fajl letrehozasakor");
            exit(1);
        }
    }

    for (int i = 0; i < line_count; i++) {
        if (stdout_mode) {
            printf("%s\n", lines[i]);
        } else {
            fprintf(file, "%s\n", lines[i]);
        }
    }

    if (!stdout_mode) {
        fclose(file);
        printf("Fajl letrehozva: %s\n", filename);
    }
}


const char *c_src[] = {
    "#include <stdio.h>",
    "",
    "int main() {",
    "    printf(\"Hello, World!\\n\");",
    "    return 0;",
    "}"
};

const char *cpp_src[] = {
    "#include <iostream>",
    "",
    "int main() {",
    "    std::cout << \"Hello, World!\" << std::endl;",
    "    return 0;",
    "}"
};

const char *py_src[] = {
    "def main():",
    "    print(\"Hello, World!\")",
    "",
    "if __name__ == \"__main__\":",
    "    main()"
};

const char *sh_src[] = {
    "#!/bin/bash",
    "",
    "echo \"Hello, World!\""
};

const char *java_src[] = {
    "public class Main {",
    "    public static void main(String[] args) {",
    "        System.out.println(\"Hello, World!\");",
    "    }",
    "}"
};


int main(int argc, char *argv[]) {
    int stdout_mode = 0;
    char *language = NULL;

    if (argc < 2) {
        print_help(argv[0]);
        return 1;
    }

    for (int i = 1; i < argc; i++) {
        if (strcmp(argv[i], "--stdout") == 0) {
            stdout_mode = 1;
        }
        else if (strcmp(argv[i], "-h") == 0 || strcmp(argv[i], "--help") == 0) {
            print_help(argv[0]);
            return 0;
        }
        else if (strcmp(argv[i], "-v") == 0 || strcmp(argv[i], "--version") == 0) {
            print_version();
            return 0;
        }
        else {
            language = argv[i];
        }
    }

    if (language == NULL) {
        printf("Nincs megadva nyelv!\n");
        return 1;
    }

    if (strcmp(language, "c") == 0) {
        output_code("main.c", c_src, 6, stdout_mode);
    }
    else if (strcmp(language, "cpp") == 0) {
        output_code("main.cpp", cpp_src, 6, stdout_mode);
    }
    else if (strcmp(language, "py") == 0) {
        output_code("main.py", py_src, 5, stdout_mode);
    }
    else if (strcmp(language, "bash") == 0) {
        output_code("main.sh", sh_src, 3, stdout_mode);
    }
    else if (strcmp(language, "java") == 0) {
        output_code("Main.java", java_src, 5, stdout_mode);
    }
    else {
        printf("Nem tamogatott nyelv: %s\n", language);
        return 2;
    }

    return 0;
}
