#include <stdio.h>
#include "prog1.h"
#include <string.h>

int contains_char(string s, char c)
{
    for(int i = 0; i < strlen(s); i++)
    {
        if(s[i] == c)
        {
            return 1;
        }
    }
        return 0;
}
//innentől csak teszteltem
int main()
{
    string s = "beta";
    char c = 'e';
    int igen_nem = contains_char(s,c);
    printf("%d\n",igen_nem);
}
