#include <stdio.h>

int legkisebb(int n,int tomb[]) {
     int min = tomb[0];
    for(int i = 1; i < n; i++) {
        if(tomb[i] < min) {
            min = tomb[i];
        }
    }
    return min;
}
int legnagyobb(int n,int tomb[]) {
     int max = tomb[0];
    for(int i = 1; i < n; i++) {
        if(tomb[i] > max) {
            max = tomb[i];
        }
    }
    return max;
}

int main()
{
    int tomb[]={2,8,1,4,9};
    int meret = 5;
    printf("A legnagyobb szam a tombben: %d\n", legnagyobb(meret,tomb));
    printf("A legkisebb szam a tombben: %d\n", legkisebb(meret,tomb));
return 0;
}
